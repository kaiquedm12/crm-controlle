generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  USER
}

enum TenantPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum CadenceStepType {
  WHATSAPP
  FOLLOW_UP
  TASK
}

enum CadenceExecutionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String
  passwordHash   String
  role           UserRole       @default(USER)
  isActive       Boolean        @default(true)
  tenantId       String?
  tenant         Tenant?        @relation(fields: [tenantId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leads          Lead[]
  activities     Activity[]
  messages       Message[]
  refreshTokens  RefreshToken[]
  createdPipes   Pipeline[]
  createdCadence Cadence[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userId    String
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Tenant {
  id         String            @id @default(cuid())
  name       String
  cnpj       String?
  email      String?
  phone      String?
  plan       TenantPlan        @default(BASIC)
  status     TenantStatus      @default(TRIAL)
  slug       String            @unique
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  users      User[]
  refreshes  RefreshToken[]
  pipelines  Pipeline[]
  stages     Stage[]
  leads      Lead[]
  deals      Deal[]
  cadences   Cadence[]
  steps      CadenceStep[]
  executions CadenceExecution[]
  messages   Message[]
  activities Activity[]
  tags       Tag[]
  leadTags   LeadTag[]
}

model Pipeline {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stages      Stage[]
  leads       Lead[]

  @@index([tenantId])
}

model Stage {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  position   Int
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  leads      Lead[]

  @@unique([pipelineId, position])
  @@index([tenantId])
}

model Lead {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id])
  pipelineId  String?
  pipeline    Pipeline?         @relation(fields: [pipelineId], references: [id])
  stageId     String?
  stage       Stage?            @relation(fields: [stageId], references: [id])
  position    Int               @default(0)
  name        String
  email       String?
  phone       String?
  company     String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  leadTags    LeadTag[]
  messages    Message[]
  activities  Activity[]
  deal        Deal?
  executions  CadenceExecution[]

  @@index([tenantId])
}

model Deal {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  leadId    String     @unique
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount    Decimal    @db.Decimal(12, 2)
  status    DealStatus @default(OPEN)
  closedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId])
}

model Cadence {
  id         String            @id @default(cuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  name       String
  isActive   Boolean           @default(true)
  createdBy  String
  user       User              @relation(fields: [createdBy], references: [id])
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  steps      CadenceStep[]
  executions CadenceExecution[]

  @@index([tenantId])
}

model CadenceStep {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  cadenceId String
  cadence   Cadence         @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  order     Int
  dayOffset Int
  type      CadenceStepType
  template  String

  @@unique([cadenceId, order])
  @@index([tenantId])
}

model CadenceExecution {
  id         String                 @id @default(cuid())
  tenantId   String
  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  cadenceId  String
  cadence    Cadence                @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status     CadenceExecutionStatus @default(ACTIVE)
  stepIndex  Int                    @default(0)
  nextRunAt  DateTime
  lastError  String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([cadenceId, leadId])
  @@index([tenantId])
}

model Message {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  leadId         String
  lead           Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?            @relation(fields: [userId], references: [id])
  direction      MessageDirection
  content        String
  providerStatus String?
  createdAt      DateTime         @default(now())

  @@index([tenantId])
}

model Activity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model Tag {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  name     String
  leadTags LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LeadTag {
  leadId    String
  tagId     String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  lead      Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId, tenantId])
  @@index([tenantId])
}
